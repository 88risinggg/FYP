{
  "name": "paynivo",
  "version": "0.1.0",
  "private": true,
  "description": "PayNivo full-stack demo app.",
  "scripts": {
    "dev": "npm run stop && concurrently -n backend,frontend -c blue,green \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "start": "npm run dev",
    "stop": "kill-port 5000 5173",
    "build": "npm --prefix frontend run build",
    "backend": "npm --prefix backend run dev",
    "frontend": "npm --prefix frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "kill-port": "^2.0.1"
  }
}
